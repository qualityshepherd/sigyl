{
  "name": "sigyl",
  "version": "1.0.0",
  "description": "A lightweight web of trust. Domain as stake. Humans required.",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:crawl": "curl \"https://sigyl.brine.dev/__scheduled?cron=*+*+*+*+*\"",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev --test-scheduled",
    "tail": "wrangler tail",
    "kv:list": "wrangler kv key list --binding=SIGYL_KV --remote",
    "kv:get": "wrangler kv key get --binding=SIGYL_KV --remote",
    "kv:put": "wrangler kv key put --binding=SIGYL_KV --remote",
    "kv:delete": "wrangler kv key delete --binding=SIGYL_KV --remote",
    "kv:trust": "wrangler kv key get --binding=SIGYL_KV trust.json",
    "secret": "wrangler secret put",
    "secret:list": "wrangler secret list",
    "pretty": "npx standard --fix"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "latest",
    "vitest": "^3.1.4"
  }
}
